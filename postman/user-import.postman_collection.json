{
  "info": {
    "name": "NNPTUD-C6 - User Import",
    "description": "Import user tu file excel va gui password qua Mailtrap",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Import Users Excel",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/upload/users_excel",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "upload",
            "users_excel"
          ]
        },
        "description": "Excel format: cot A = username, cot B = email; dong 1 la header"
      },
      "response": []
    },
    {
      "name": "Upload One File (optional check)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/upload/one_file",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "upload",
            "one_file"
          ]
        }
      },
      "response": []
    }
  ]
}
